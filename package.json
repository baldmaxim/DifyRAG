{
  "name": "document-knowledge-portal",
  "version": "0.1.0",
  "private": true,
  "description": "Dify-first Document Knowledge Portal for a construction company",
  "packageManager": "pnpm@11.10.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "pnpm --parallel --filter \"./apps/*\" dev",
    "build": "pnpm --filter @dkp/shared build && pnpm --filter \"./apps/*\" build",
    "typecheck": "pnpm --filter @dkp/shared build && pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "db:migrate": "pnpm --filter @dkp/api db:migrate",
    "seed": "pnpm --filter @dkp/api seed"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  }
}
