// Document Knowledge Portal — Prisma schema.
// Enum string values mirror @dkp/shared; PostgreSQL is the single source of truth
// for metadata, versions, permissions, jobs, audit and (in prompt 04) Dify mappings.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Enums ────────────────────────────────────────────────────

enum UserRole {
  super_admin
  admin
  manager
  editor
  viewer
}

enum UserStatus {
  active
  disabled
}

enum ApiKeyStatus {
  active
  revoked
}

enum ProjectStatus {
  active
  archived
}

enum Scope {
  project
  company
  people
  contractors
  reference
  templates
}

enum DocumentStatus {
  draft
  active
  uploading
  stored
  queued
  processing
  indexed
  error
  deleted
}

enum Confidentiality {
  public
  internal
  confidential
  restricted
}

enum UploadSource {
  web
  external_api
  system
}

enum UploadSessionStatus {
  created
  uploaded
  committed
  expired
  failed
}

enum ProcessingJobType {
  dify_create_document
  dify_update_document
  dify_archive_document
  dify_restore_document
  dify_reindex_document
  dify_poll_indexing_status
}

enum ProcessingJobStatus {
  queued
  running
  success
  failed
  skipped
}

enum ProcessingProvider {
  dify
}

enum ActorType {
  user
  api_key
  system
}

enum ProjectMemberRole {
  owner
  manager
  editor
  viewer
}

// ── Users & auth ─────────────────────────────────────────────

model User {
  id           String     @id @default(uuid()) @db.Uuid
  email        String     @unique
  passwordHash String     @map("password_hash")
  fullName     String     @map("full_name")
  role         UserRole   @default(viewer)
  status       UserStatus @default(active)
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  refreshTokens    RefreshToken[]
  createdApiKeys   ApiKey[]          @relation("ApiKeyCreatedBy")
  projectMembers   ProjectMember[]
  uploadedVersions DocumentVersion[]
  createdDocuments Document[]        @relation("DocumentCreatedBy")
  updatedDocuments Document[]        @relation("DocumentUpdatedBy")
  deletedDocuments Document[]        @relation("DocumentDeletedBy")

  @@map("users")
}

model RefreshToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

model ApiKey {
  id              String       @id @default(uuid()) @db.Uuid
  name            String
  prefix          String       @unique
  secretHash      String       @map("secret_hash")
  scopes          String[]
  status          ApiKeyStatus @default(active)
  createdByUserId String       @map("created_by_user_id") @db.Uuid
  lastUsedAt      DateTime?    @map("last_used_at")
  expiresAt       DateTime?    @map("expires_at")
  createdAt       DateTime     @default(now()) @map("created_at")
  revokedAt       DateTime?    @map("revoked_at")

  createdBy User @relation("ApiKeyCreatedBy", fields: [createdByUserId], references: [id])

  @@map("api_keys")
}

// ── Projects, departments, folders ───────────────────────────

model Project {
  id           String        @id @default(uuid()) @db.Uuid
  code         String        @unique
  name         String
  description  String?
  address      String?
  customerName String?       @map("customer_name")
  status       ProjectStatus @default(active)
  metadata     Json?
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")

  folders   Folder[]
  documents Document[]
  members   ProjectMember[]

  @@map("projects")
}

model Department {
  id             String   @id @default(uuid()) @db.Uuid
  slug           String   @unique
  name           String
  description    String?
  skillsMarkdown String?  @map("skills_markdown")
  metadata       Json?
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  folders   Folder[]
  documents Document[]

  @@map("departments")
}

model Folder {
  id           String   @id @default(uuid()) @db.Uuid
  scope        Scope
  projectId    String?  @map("project_id") @db.Uuid
  departmentId String?  @map("department_id") @db.Uuid
  parentId     String?  @map("parent_id") @db.Uuid
  slug         String
  name         String
  path         String
  sortOrder    Int      @default(0) @map("sort_order")
  metadata     Json?
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  project    Project?    @relation(fields: [projectId], references: [id])
  department Department? @relation(fields: [departmentId], references: [id])
  parent     Folder?     @relation("FolderChildren", fields: [parentId], references: [id])
  children   Folder[]    @relation("FolderChildren")
  documents  Document[]

  @@unique([scope, projectId, path])
  @@index([projectId])
  @@index([parentId])
  @@map("folders")
}

model DocumentType {
  id          String  @id @default(uuid()) @db.Uuid
  code        String  @unique
  name        String
  description String?
  metadata    Json?

  documents Document[]

  @@map("document_types")
}

// ── Documents & versions ─────────────────────────────────────

model Document {
  id               String          @id @default(uuid()) @db.Uuid
  scope            Scope
  projectId        String?         @map("project_id") @db.Uuid
  departmentId     String?         @map("department_id") @db.Uuid
  folderId         String          @map("folder_id") @db.Uuid
  documentTypeId   String          @map("document_type_id") @db.Uuid
  title            String
  description      String?
  documentDate     DateTime?       @map("document_date")
  counterparty     String?
  contractNumber   String?         @map("contract_number")
  status           DocumentStatus  @default(draft)
  confidentiality  Confidentiality @default(internal)
  accessGroup      String?         @map("access_group")
  currentVersionId String?         @unique @map("current_version_id") @db.Uuid
  metadata         Json?
  deletedAt        DateTime?       @map("deleted_at")
  deletedByUserId  String?         @map("deleted_by_user_id") @db.Uuid
  createdByUserId  String          @map("created_by_user_id") @db.Uuid
  updatedByUserId  String?         @map("updated_by_user_id") @db.Uuid
  createdAt        DateTime        @default(now()) @map("created_at")
  updatedAt        DateTime        @updatedAt @map("updated_at")

  project        Project?            @relation(fields: [projectId], references: [id])
  department     Department?         @relation(fields: [departmentId], references: [id])
  folder         Folder              @relation(fields: [folderId], references: [id])
  documentType   DocumentType        @relation(fields: [documentTypeId], references: [id])
  currentVersion DocumentVersion?    @relation("CurrentVersion", fields: [currentVersionId], references: [id])
  versions       DocumentVersion[]   @relation("DocumentVersions")
  uploadSessions FileUploadSession[]
  processingJobs ProcessingJob[]
  createdBy      User                @relation("DocumentCreatedBy", fields: [createdByUserId], references: [id])
  updatedBy      User?               @relation("DocumentUpdatedBy", fields: [updatedByUserId], references: [id])
  deletedBy      User?               @relation("DocumentDeletedBy", fields: [deletedByUserId], references: [id])

  @@index([projectId])
  @@index([folderId])
  @@index([status])
  @@map("documents")
}

model DocumentVersion {
  id               String       @id @default(uuid()) @db.Uuid
  documentId       String       @map("document_id") @db.Uuid
  versionNo        Int          @map("version_no")
  originalFileName String       @map("original_file_name")
  mimeType         String       @map("mime_type")
  sizeBytes        BigInt       @map("size_bytes")
  checksumSha256   String       @map("checksum_sha256")
  s3Bucket         String       @map("s3_bucket")
  s3Key            String       @map("s3_key")
  s3VersionId      String?      @map("s3_version_id")
  uploadedByUserId String?      @map("uploaded_by_user_id") @db.Uuid
  uploadSource     UploadSource @default(web) @map("upload_source")
  isCurrent        Boolean      @default(false) @map("is_current")
  createdAt        DateTime     @default(now()) @map("created_at")

  document       Document        @relation("DocumentVersions", fields: [documentId], references: [id], onDelete: Cascade)
  currentOf      Document?       @relation("CurrentVersion")
  uploadedBy     User?           @relation(fields: [uploadedByUserId], references: [id])
  processingJobs ProcessingJob[]

  @@unique([documentId, versionNo])
  @@index([documentId])
  @@map("document_versions")
}

model FileUploadSession {
  id                String              @id @default(uuid()) @db.Uuid
  documentId        String?             @map("document_id") @db.Uuid
  intendedFileName  String              @map("intended_file_name")
  mimeType          String              @map("mime_type")
  sizeBytes         BigInt?             @map("size_bytes")
  checksumSha256    String?             @map("checksum_sha256")
  s3Bucket          String              @map("s3_bucket")
  s3Key             String              @map("s3_key")
  status            UploadSessionStatus @default(created)
  expiresAt         DateTime            @map("expires_at")
  createdByUserId   String?             @map("created_by_user_id") @db.Uuid
  createdByApiKeyId String?             @map("created_by_api_key_id") @db.Uuid
  createdAt         DateTime            @default(now()) @map("created_at")
  committedAt       DateTime?           @map("committed_at")

  document Document? @relation(fields: [documentId], references: [id])

  @@index([documentId])
  @@map("file_upload_sessions")
}

// ── Processing & audit ───────────────────────────────────────

model ProcessingJob {
  id                String              @id @default(uuid()) @db.Uuid
  documentId        String?             @map("document_id") @db.Uuid
  documentVersionId String?             @map("document_version_id") @db.Uuid
  jobType           ProcessingJobType   @map("job_type")
  status            ProcessingJobStatus @default(queued)
  provider          ProcessingProvider  @default(dify)
  attempts          Int                 @default(0)
  errorMessage      String?             @map("error_message")
  startedAt         DateTime?           @map("started_at")
  finishedAt        DateTime?           @map("finished_at")
  createdAt         DateTime            @default(now()) @map("created_at")
  updatedAt         DateTime            @updatedAt @map("updated_at")

  document        Document?        @relation(fields: [documentId], references: [id])
  documentVersion DocumentVersion? @relation(fields: [documentVersionId], references: [id])

  @@index([documentId])
  @@index([status])
  @@map("processing_jobs")
}

model AuditLog {
  id            String    @id @default(uuid()) @db.Uuid
  actorType     ActorType @map("actor_type")
  actorUserId   String?   @map("actor_user_id") @db.Uuid
  actorApiKeyId String?   @map("actor_api_key_id") @db.Uuid
  action        String
  resourceType  String    @map("resource_type")
  resourceId    String    @map("resource_id")
  ip            String?
  userAgent     String?   @map("user_agent")
  before        Json?
  after         Json?
  createdAt     DateTime  @default(now()) @map("created_at")

  @@index([resourceType, resourceId])
  @@index([actorUserId])
  @@index([createdAt])
  @@map("audit_logs")
}

model ProjectMember {
  id        String            @id @default(uuid()) @db.Uuid
  projectId String            @map("project_id") @db.Uuid
  userId    String            @map("user_id") @db.Uuid
  role      ProjectMemberRole @default(viewer)
  createdAt DateTime          @default(now()) @map("created_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@map("project_members")
}
