# ─────────────────────────────────────────────────────────────
# App
# ─────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
CORS_ORIGIN=http://localhost:5173

# ─────────────────────────────────────────────────────────────
# Database (Managed PostgreSQL in production)
# ─────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/document_portal

# ─────────────────────────────────────────────────────────────
# Auth
# ─────────────────────────────────────────────────────────────
JWT_SECRET=change-me
JWT_REFRESH_SECRET=change-me
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# ─────────────────────────────────────────────────────────────
# S3 (Cloud.ru S3-compatible Object Storage)
# Access keys should NOT have DeleteObject permission.
# ─────────────────────────────────────────────────────────────
S3_ENDPOINT=
S3_REGION=ru-central-1
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_FORCE_PATH_STYLE=true
S3_PRESIGNED_URL_TTL_SECONDS=900
MAX_FILE_SIZE_BYTES=524288000

# ─────────────────────────────────────────────────────────────
# Dify (primary RAG engine)
# ─────────────────────────────────────────────────────────────
DIFY_ENABLED=true
DIFY_BASE_URL=http://localhost
DIFY_API_PREFIX=/v1
DIFY_KNOWLEDGE_API_KEY=
DIFY_APP_API_KEY=
DIFY_TIMEOUT_MS=120000
DIFY_AUTO_CREATE_DATASETS=true
DIFY_DATASET_STRATEGY=project_section
DIFY_DEFAULT_INDEXING_TECHNIQUE=high_quality
DIFY_DEFAULT_DOC_FORM=text_model
DIFY_DEFAULT_DOC_LANGUAGE=Russian
DIFY_CHUNK_MAX_TOKENS=700
DIFY_CHUNK_OVERLAP=80
DIFY_RETRIEVE_TOP_K=12
DIFY_RETRIEVE_SCORE_THRESHOLD=0.2

# ─────────────────────────────────────────────────────────────
# LM Studio (OpenAI-compatible embedding/LLM provider)
# Model + dimension are env-driven and MUST match the model actually loaded in
# LM Studio for THIS environment. Dify picks the embedding model in its own KB
# config; these vars only drive the LM Studio health check.
#   SERVER (production): Qwen/Qwen3-Embedding-8B → dim 4096 (values below).
#   LOCAL testing: load a smaller installed model and set BOTH to its real values:
#     LM_STUDIO_EMBEDDING_MODEL=<id from GET /v1/models>   e.g. nomic-embed-text-v1.5
#     LM_STUDIO_EXPECTED_EMBEDDING_DIMENSION=<its real dim>  e.g. 384 / 768 / 1024
#   Leave EXPECTED_EMBEDDING_DIMENSION empty/0 to skip the dimension check entirely.
# ─────────────────────────────────────────────────────────────
LM_STUDIO_BASE_URL=http://host.docker.internal:1234/v1
LM_STUDIO_EMBEDDING_MODEL=qwen3-embedding-8b
LM_STUDIO_EXPECTED_EMBEDDING_DIMENSION=4096
LM_STUDIO_TIMEOUT_MS=60000

# ─────────────────────────────────────────────────────────────
# Qdrant (managed by Dify; app uses read-only health only)
# ─────────────────────────────────────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_HEALTHCHECK_ENABLED=true

# ─────────────────────────────────────────────────────────────
# Queue (pg-boss) & processing worker
# ─────────────────────────────────────────────────────────────
PG_BOSS_SCHEMA=pgboss
# Enable the background worker that pushes documents to Dify and polls status.
# Requires a live DATABASE_URL and reachable Dify.
PROCESSING_WORKER_ENABLED=false
PROCESSING_POLL_INTERVAL_MS=4000
PROCESSING_MAX_ATTEMPTS=5

# ─────────────────────────────────────────────────────────────
# Security limits
# ─────────────────────────────────────────────────────────────
EXTERNAL_RATE_LIMIT_PER_MIN=120
# Passphrase used to encrypt UI-managed secrets (S3/Dify/Qdrant keys) at rest.
# Bootstrap-only — must live in env. Use a long random value; changing it makes
# previously stored UI secrets unreadable (re-enter them in the UI).
SETTINGS_ENCRYPTION_KEY=change-me-to-a-long-random-passphrase

# ─────────────────────────────────────────────────────────────
# Seed (super admin bootstrap)
# ─────────────────────────────────────────────────────────────
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=change-me-strong
SEED_ADMIN_FULL_NAME=Portal Administrator
